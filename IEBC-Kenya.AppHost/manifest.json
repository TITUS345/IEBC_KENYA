{
  "resources": {
    "votingdb": {
      "type": "parameter.v0",
      "connectionString": "{votingdb.value}",
      "value": "{votingdb.inputs.value}",
      "inputs": {
        "value": {
          "type": "string",
          "secret": true
        }
      }
    },
    "api": {
      "type": "project.v1",
      "path": "../IEBCVotingSystemV10/IEBCVotingSystemV10.csproj",
      "env": {
        "OTEL_DOTNET_EXPERIMENTAL_OTLP_RETRY": "in_memory",
        "ASPNETCORE_FORWARDEDHEADERS_ENABLED": "true",
        "HTTP_PORTS": "{api.bindings.http.targetPort};{api.bindings.api-http.targetPort}",
        "JWT_KEY": "IEBC_VOTING_SYSTEM_SUPER_SECRET_KEY_2026_SECURE_LONG_STRING_123",
        "ConnectionStrings__votingdb": "{votingdb.connectionString}",
        "FRONTEND_BASE_URL": "http://192.168.100.34:3000",
        "OTEL_EXPORTER_OTLP_ENDPOINT": "{docker-env-dashboard.bindings.otlp-grpc.url}",
        "OTEL_EXPORTER_OTLP_PROTOCOL": "grpc",
        "OTEL_SERVICE_NAME": "api"
      },
      "bindings": {
        "http": {
          "scheme": "http",
          "protocol": "tcp",
          "transport": "http",
          "external": true
        },
        "https": {
          "scheme": "https",
          "protocol": "tcp",
          "transport": "http",
          "external": true
        },
        "api-http": {
          "scheme": "http",
          "protocol": "tcp",
          "transport": "http",
          "targetPort": 5007,
          "external": true
        }
      }
    },
    "frontend": {
      "type": "container.v1",
      "build": {
        "context": "../iebc-voting-system-frontend",
        "dockerfile": "../iebc-voting-system-frontend/Dockerfile"
      },
      "env": {
        "PORT": "{frontend.bindings.http.targetPort}",
        "API_HTTP": "{api.bindings.http.url}",
        "services__api__http__0": "{api.bindings.http.url}",
        "API_HTTPS": "{api.bindings.https.url}",
        "services__api__https__0": "{api.bindings.https.url}",
        "API_API_HTTP": "{api.bindings.api-http.url}",
        "services__api__http__1": "{api.bindings.api-http.url}"
      },
      "bindings": {
        "http": {
          "scheme": "http",
          "protocol": "tcp",
          "transport": "http",
          "targetPort": 3000
        }
      }
    },
    "docker-env": {
      "error": "This resource does not support generation in the manifest."
    },
    "docker-env-dashboard": {
      "type": "container.v1",
      "image": "mcr.microsoft.com/dotnet/nightly/aspire-dashboard:latest",
      "bindings": {
        "http": {
          "scheme": "http",
          "protocol": "tcp",
          "transport": "http",
          "targetPort": 18888,
          "external": true
        },
        "otlp-grpc": {
          "scheme": "http",
          "protocol": "tcp",
          "transport": "http",
          "targetPort": 18889
        },
        "otlp-http": {
          "scheme": "http",
          "protocol": "tcp",
          "transport": "http",
          "targetPort": 18890
        }
      }
    }
  }
}